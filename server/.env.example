PORT=5001
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret
OMDB_API_KEY=your_omdb_api_key
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
# Comma-separated list of allowed frontend origins for browser requests.
# Required in production.
# Example: CORS_ORIGINS=https://watchit.example.com,https://www.watchit.example.com
CORS_ORIGINS=http://localhost:5173

# SMTP config for verification and password reset email delivery.
# For SendGrid SMTP use:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=<your-sendgrid-api-key>
# Optional direct SendGrid Web API key (recommended when SMTP ports are blocked):
# SENDGRID_API_KEY=<your-sendgrid-api-key>
# EMAIL_FROM=Verified Sender <your-verified-sender@domain.com>
# If unset, links are logged on the server in development.
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SENDGRID_API_KEY=
EMAIL_FROM=

# Shared test/admin account (auto-created on server startup)
# Keep disabled by default so admin bypass is not public.
ENABLE_TEST_ADMIN=false
# TEST_ADMIN_USERNAME=admin
# TEST_ADMIN_EMAIL=admin@watchit.local
# TEST_ADMIN_PASSWORD=your_local_test_admin_password
