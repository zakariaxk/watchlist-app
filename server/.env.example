PORT=5001
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret
OMDB_API_KEY=your_omdb_api_key
FRONTEND_URL=http://localhost:5173

# SMTP config for verification and password reset email delivery.
# For SendGrid SMTP use:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=<your-sendgrid-api-key>
# EMAIL_FROM=Verified Sender <your-verified-sender@domain.com>
# If unset, links are logged on the server in development.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
